{
  "family": "sever-api-beta",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::778477254868:role/sever-beta-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::778477254868:role/sever-beta-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "sever-api",
      "image": "778477254868.dkr.ecr.us-east-1.amazonaws.com/sever-api:beta-latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SEVER_ENV", "value": "beta" },
        { "name": "AUTH_MODE", "value": "cognito" },
        { "name": "COGNITO_REGION", "value": "us-east-1" },
        { "name": "COGNITO_USER_POOL_ID", "value": "us-east-1_Bx7hEfpPN" },
        { "name": "COGNITO_APP_CLIENT_ID", "value": "1rgbh29kj0k9g2ob44dqj8nd7l" }
      ],
      "secrets": [
        {
          "name": "SEVER_INTERNAL_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:778477254868:secret:sever/beta/internal-token-G6J4Ls"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sever-beta/api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "beta"
        }
      }
    }
  ]
}
