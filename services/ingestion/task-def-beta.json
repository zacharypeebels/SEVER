{
  "family": "sever-ingestion-beta",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::778477254868:role/sever-beta-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::778477254868:role/sever-beta-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "sever-ingestion",
      "image": "778477254868.dkr.ecr.us-east-1.amazonaws.com/sever-ingestion:beta-latest",
      "essential": true,
      "environment": [
        { "name": "SEVER_ENV", "value": "beta" },
        { "name": "SEVER_INGEST_MODE", "value": "sandbox" }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sever-beta/ingestion",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "beta"
        }
      }
    }
  ]
}
